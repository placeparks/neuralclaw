# Postgres (required)
DATABASE_URL=
DIRECT_URL=

# Auth
AUTH_SESSION_SECRET=

# Railway owner mode (recommended for deployments in your Railway account)
RAILWAY_OWNER_MODE=true
RAILWAY_API_TOKEN=
RAILWAY_PROJECT_ID=
RAILWAY_SERVICE_ID=
RAILWAY_BASE_ENVIRONMENT_ID=

# Optional custom endpoint (default shown)
# RAILWAY_GRAPHQL_ENDPOINT=https://backboard.railway.com/graphql/v2

# Fallback template mode (used only if RAILWAY_OWNER_MODE=false)
RAILWAY_TEMPLATE_SLUG=
RAILWAY_DEPLOY_URL=

# Optional referral
RAILWAY_REFERRAL_CODE=

# Stripe disabled intentionally in testing mode
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
