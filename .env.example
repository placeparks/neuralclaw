# Postgres (required)
DATABASE_URL=
DIRECT_URL=

# Auth
AUTH_SESSION_SECRET=

# Railway owner mode (service-per-user)
RAILWAY_OWNER_MODE=true
RAILWAY_API_TOKEN=
RAILWAY_PROJECT_ID=
# Source/template service ID to clone for each user deployment
RAILWAY_SERVICE_ID=
# Target environment where cloned services are deployed (e.g., production)
RAILWAY_BASE_ENVIRONMENT_ID=

# Optional custom endpoint
# RAILWAY_GRAPHQL_ENDPOINT=https://backboard.railway.com/graphql/v2

# Fallback template mode (used only when RAILWAY_OWNER_MODE=false)
RAILWAY_TEMPLATE_SLUG=
RAILWAY_DEPLOY_URL=
RAILWAY_REFERRAL_CODE=
