NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DEPLOYMENT_TOKEN_SECRET=

# Provisioner security
PROVISIONER_SECRET=

# Railway API provisioning
RAILWAY_API_TOKEN=
RAILWAY_PROJECT_ID=
RAILWAY_ENVIRONMENT_ID=

# Runtime template repo (recommended)
RAILWAY_RUNTIME_TEMPLATE_REPO=your-github-org/neuralclaw-runtime-template
RAILWAY_RUNTIME_TEMPLATE_BRANCH=main

# Legacy names (optional backward compatibility)
RAILWAY_TEMPLATE_REPO=
RAILWAY_TEMPLATE_BRANCH=

RAILWAY_SERVICE_PREFIX=neuralclaw
DEPLOYMENT_BASE_URL=https://your-railway-app.up.railway.app
NEXT_PUBLIC_COMPANION_WINDOWS_URL=https://github.com/your-github-org/neuralclaw/releases/latest/download/neuralclaw-companion-setup-0.1.0.exe

# WhatsApp via Evolution API (optional — enables QR fallback in dashboard)
# Self-host: https://github.com/EvolutionAPI/evolution-api
NEURALCLAW_WHATSAPP_BRIDGE_URL=https://your-evolution-api.example.com
NEURALCLAW_WHATSAPP_BRIDGE_API_KEY=your-evolution-api-key
